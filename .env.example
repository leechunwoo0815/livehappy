# Database
DATABASE_URL=postgresql+asyncpg://你的用户名@localhost:5432/stayhub

# Redis (可选，不配置则自动降级为内存存储)
REDIS_URL=redis://localhost:6379/0

# JWT (必须修改为随机密钥)
JWT_SECRET_KEY=your_random_secret_key_here

# App
DEBUG=true
CORS_ORIGINS=http://localhost:8001,http://localhost:3001

# DeepSeek AI (可选)
DEEPSEEK_API_KEY=
AI_ENABLED=false

# Upload
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
