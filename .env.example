# Database
POSTGRES_DB=stayhub
POSTGRES_USER=stayhub
POSTGRES_PASSWORD=change_this_password
DATABASE_URL=postgresql+asyncpg://stayhub:change_this_password@postgres:5432/stayhub

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=generate_a_random_secret_key_here

# App
DEBUG=false
CORS_ORIGINS=http://localhost:3001,https://your-production-domain.com

# Elasticsearch (optional)
ELASTICSEARCH_ENABLED=false
ELASTICSEARCH_HOSTS=http://localhost:9200

# DeepSeek AI (optional)
DEEPSEEK_API_KEY=
AI_ENABLED=false

# Upload
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
